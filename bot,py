async def presets_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Show available image size presets."""
    presets_msg = (
        "*📐 Available Image Sizes for Instagram*\n\n"
        "• *Square* - 1024×1024 (1:1)\n"
        "  Best for: Standard feed posts\n\n"
